# Supabase Configuration
# Get these values from your Supabase project settings at https://app.supabase.com/

# Your Supabase project URL
# You can find this at: Settings > API > Project URL
VITE_SUPABASE_URL=your_supabase_url_here

# Your Supabase anonymous key (public)
# You can find this at: Settings > API > Project API keys (anon key)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
